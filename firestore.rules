rules_version = '2';

// Regras do Firestore para o Tichr.
//
// O backend usa o **Admin SDK**, que IGNORA estas regras — toda a escrita de
// dados passa por ele. Estas regras existem para o **cliente Angular**, que a
// partir do Tichr Qlick lê a coleção de partidas em tempo real (`onSnapshot`).
//
// Deploy (a partir deste repo): `firebase deploy --only firestore:rules`.
service cloud.firestore {
  match /databases/{database}/documents {

    // Partidas do Tichr Qlick: estado efêmero e público (o aluno lê para jogar).
    // Escrita SOMENTE pelo backend (Admin SDK) — o cliente nunca escreve.
    match /qlick_partidas/{partidaId} {
      allow read: if true;
      allow write: if false;
    }

    // Partidas do Tichr Wor (estado fragmentado): documento raiz + subcoleção de
    // equipes. Dados não sensíveis (máscara da palavra, HP, cartas reveladas);
    // o projetor e o celular do aluno leem em tempo real (onSnapshot). Escrita
    // SOMENTE pelo backend (Admin SDK).
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;

      match /teams/{teamId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Tichr Isolateus: SÓ o documento da partida é público. Ele é montado para
    // não entregar o mistério — nele não há o Alienígena, nem a marca de quem é
    // NPC, nem a alternativa correta da questão no ar.
    //
    // O cofre (`isolateus_segredos`), as respostas (`isolateus_respostas`) e os
    // votos da Quarentena (`isolateus_votos`) caem no deny-all abaixo, de
    // propósito: fossem legíveis, bastaria abrir o DevTools para saber quem é o
    // infiltrado. O aluno recebe a sua fatia por REST autenticado.
    match /isolateus_partidas/{partidaId} {
      allow read: if true;
      allow write: if false;
    }

    // Todas as demais coleções (turmas, alunos, qlicks, e os segredos do
    // Isolateus) ficam fechadas ao cliente — só o Admin SDK do backend as acessa.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
